rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Invoices remain locked
    match /invoices/{allPaths=**} {
      allow read, write: if false;
    }

    // Proof images: authenticated users can upload/read their own order proofs
    match /proofs/{userId}/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024;
    }

    // Bank transfer proof images
    match /transfers/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024;
    }

    // Everything else locked
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
